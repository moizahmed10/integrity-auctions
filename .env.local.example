# Google Sheets Spreadsheet ID (from the URL: https://docs.google.com/spreadsheets/d/{THIS_ID}/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials JSON (single line, escaped)
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable the Google Sheets API, download the JSON key, then paste the entire JSON here as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
